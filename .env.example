# LLM provider for analysis: "anthropic" (default) or "openai".
# Set to "openai" to spend OpenAI credits; flip back to "anthropic" when they run out
# (a banner warns you on insufficient_quota). Changing this requires restarting the app.
LLM_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANALYSIS_MODEL=claude-sonnet-4-6

# OpenAI — OPENAI_MODEL must support the web_search tool via the Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

POLYMARKET_API_BASE=https://gamma-api.polymarket.com
ANALYSIS_DELAY_SECONDS=1.5
MAX_SCAN_MARKETS=100

# Hard ceiling on fresh LLM calls (market analyses + refutations) per scan, so a single scan
# can't burn through your API credits. Reused/cached analyses are free and don't count.
# 0 (default) = no cap. Applies to manual scans (as the default) AND scheduled auto-scans; a
# value in the /api/scan request body overrides this. Set e.g. 20 to keep refilled credits lasting.
MAX_LLM_CALLS_PER_SCAN=0

# Assumed tokens per call for the dry-run cost preview (POST /api/scan/estimate + the UI's
# "Estimate (no spend)" button). The preview prices estimated_calls with the CURRENT model's
# per-token rate (see src/research/pricing.py) x these token counts — a ballpark for sizing a
# scan before running it. The post-scan run log records the TRUE cost from real token usage.
EST_INPUT_TOKENS=1500
EST_OUTPUT_TOKENS=700
# Assumed server-side web searches per call for the estimate. Each search bills a tool fee
# (~$0.01) on TOP of tokens, so the preview adds est_searches x fee to each call's cost. The
# real per-analysis cost (recorded post-scan) counts the actual searches the model ran.
EST_WEB_SEARCHES=3

# Which exchange the scanner fetches from: "polymarket" (default) | "kalshi" | "both".
# Kalshi market data is public — no key needed. Kalshi markets are discovered via /events
# (the raw /markets listing is ~99% auto-generated MVE parlays); edges price off the live
# by-ticker order book and produce forward signals/alerts just like Polymarket.
EXCHANGE=polymarket

# Kalshi discovery: comma-separated liquid, fast-resolving series to query directly (weather,
# econ releases, crypto daily). The broad /events listing under-surfaces near-dated markets, so
# we hit /markets?series_ticker=... per series. Empty = fall back to /events discovery. Sports
# game-outcome series are excluded by default (efficient markets, no LLM edge). See DEFAULT_KALSHI_SERIES.
KALSHI_SERIES=KXHIGHNY,KXHIGHCHI,KXHIGHLAX,KXHIGHMIA,KXHIGHAUS,KXCPIYOY,KXPAYROLLS,KXFEDDECISION,KXBTCD,KXETHD

# Lifetime-volume floor for Kalshi markets in the scanner pre-filter. Kalshi doesn't
# populate 24h volume, so Kalshi is gated on volume_total instead of min_volume_24h.
# (Polymarket still uses the per-scan min_volume_24h.)
KALSHI_MIN_VOLUME=5000

# Kalshi auth is OPTIONAL and only needed for trading / higher rate limits — public
# market-data reads work with both blank. If set (both required), requests are RSA-PSS
# signed (needs the 'cryptography' package). KALSHI_KEY_FILE points to a PEM private key.
KALSHI_API_BASE=https://api.elections.kalshi.com
KALSHI_API_KEY=
KALSHI_KEY_FILE=

# Target position size (USD) for executable EV. The scanner walks the order book and
# prices each edge at the volume-weighted average fill to deploy this much on the
# favorable side — depth-aware, so thin books show a worse (truer) price than top-of-book.
TARGET_POSITION_USD=50

# Manual-trade sizing for the Signals trade-ticket: BANKROLL_USD is the account the
# recommended stake scales against; KELLY_FRACTION is the fraction of full Kelly used
# (0.25 = quarter-Kelly, conservative — sensible while the model is uncalibrated). The
# recommended stake is min(fraction * kelly * bankroll, book-depth, bankroll, MAX_POSITION_USD).
BANKROLL_USD=200
KELLY_FRACTION=0.25
# Hard per-position cap (USD; 0 = no cap). Keep small while the model is uncalibrated — Kelly
# sizes big on extreme-longshot edges where LLMs are least reliable. Raise as the edge proves out.
MAX_POSITION_USD=10

# Adversarial pressure-test: refute the top N ranked edges before they're shown as bets (the
# skeptic argues the other side; an edge that doesn't hold is flagged). Shares MAX_LLM_CALLS_PER_SCAN,
# so total spend stays bounded. 0 = off. Applies to scheduled auto-scans (manual scans pass refute_top).
REFUTE_TOP=3

# Adversarial refutation: when "true", the skeptic uses the provider OPPOSITE the
# analysis (Claude refutes OpenAI edges and vice-versa). Requires BOTH provider keys;
# if the opposite key is missing it falls back to same-model (logged). Blank = same-model.
CROSS_MODEL_ADVERSARIAL=

# Background auto-scan: hours between scan + resolution-sweep runs (blank/0 = off).
# Each run spends LLM budget (bounded by MAX_SCAN_MARKETS); set >= 24 so analyses are
# fresh (within max_age_hours they'd be reused and markets_scanned would read ~0).
# Logs one JSON line per run to data/scan_log.jsonl.
SCAN_INTERVAL_HOURS=

# Auto-scan gate overrides (blank = ScanRequest defaults). SCAN_MAX_DAYS_TO_CLOSE caps how
# far out a scanned market may close (0 = no cap) — set e.g. 30 to bias toward near-dated
# markets so resolved (estimate, outcome) pairs accrue fast while building calibration.
# SCAN_MIN_DAYS_TO_CLOSE lowers the 7-day floor; SCAN_MIN_VOLUME_24H overrides the volume gate.
SCAN_MIN_DAYS_TO_CLOSE=
SCAN_MAX_DAYS_TO_CLOSE=
SCAN_MIN_VOLUME_24H=

# Safety brake: skip the auto-scan once cumulative Claude analysis spend reaches this USD amount
# (0 = off). Stops runaway spend from outpacing ROI; the per-scan MAX_LLM_CALLS_PER_SCAN cap still applies.
SPEND_CAP_USD=0

# Flag signals whose |our prob − market mid| >= this as likely model misreads (wrong threshold/
# date/stale data): auto-stake is withheld and they're routed to the divergence-review panel. 0.40 = 40pp.
EXTREME_DIVERGENCE=0.40

# Liquidity guard: only log a forward signal if the live book fills at least this much USD on the
# chosen side at the modeled VWAP — no signals on books too thin to actually trade.
MIN_BOOK_DEPTH_USD=20

# Resolution-only sweep cadence (hours; blank/0 = off). Independent of SCAN_INTERVAL_HOURS.
# Sweeps are cheap (Gamma/Kalshi only, NO LLM spend), so run them more often than full scans to
# capture resolutions before markets drop out of the active set. App-log only (not scan_log).
#
# This is the calibration flywheel: a sweep marks closed markets resolved and settles open
# signals, which is what gives each model resolved (estimate, outcome) pairs. A new model
# (e.g. after a provider switch) is UNCALIBRATED until it crosses CALIBRATION_MIN_N resolved
# pairs — so set this to a small value (e.g. 6) and let it run; the Leaderboard/Calibration
# views fill in over time. Don't size real positions on a model until its pairs confirm it.
AUTO_RESOLUTION_INTERVAL_HOURS=

# Stale re-analysis cadence (hours; blank/0 = off). Periodically re-analyzes markets whose
# price drifted past STALE_THRESHOLD since their last analysis. Spends LLM budget, so each
# run is capped at STALE_REANALYZE_MAX markets. App-log only (not scan_log).
STALE_REANALYZE_INTERVAL_HOURS=
STALE_REANALYZE_MAX=20

# Tunable bands (blank = defaults). STALE_THRESHOLD: price move (0-1) that flags an analysis
# stale (default 0.04). FAIR_BAND: |estimate - market| within this is "fair" (default 0.03).
# REFUTE_BAND: how far past the market a refuter must stay for an edge to "hold" (default 0.03).
STALE_THRESHOLD=0.04
FAIR_BAND=0.03
REFUTE_BAND=0.03

# Forward signal log: per-share EV floor an executable edge must clear to be logged as a
# forward signal (blank = 0.0). Auto-scans log automatically; manual scans only with
# {"log_signals": true}. Positions are sized at TARGET_POSITION_USD (above) and scored for
# realized P&L when the market resolves.
SIGNAL_MIN_EV=

# High-divergence alerts: an actionable edge (executable, ev>0) whose calibrated estimate
# diverges from the market mid by at least ALERT_MIN_DIVERGENCE is written to
# data/alerts.jsonl + the app log. ALERT_COOLDOWN_HOURS suppresses repeat alerts for the
# same market. If ALERT_WEBHOOK_URL is set, each alert is also POSTed (best-effort, stdlib).
ALERT_MIN_DIVERGENCE=0.15
ALERT_COOLDOWN_HOURS=24
ALERT_WEBHOOK_URL=
