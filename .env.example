# LLM provider for analysis: "anthropic" (default) or "openai".
# Set to "openai" to spend OpenAI credits; flip back to "anthropic" when they run out
# (a banner warns you on insufficient_quota). Changing this requires restarting the app.
LLM_PROVIDER=anthropic

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANALYSIS_MODEL=claude-sonnet-4-6

# OpenAI — OPENAI_MODEL must support the web_search tool via the Responses API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

POLYMARKET_API_BASE=https://gamma-api.polymarket.com
ANALYSIS_DELAY_SECONDS=1.5
MAX_SCAN_MARKETS=100

# Target position size (USD) for executable EV. The scanner walks the order book and
# prices each edge at the volume-weighted average fill to deploy this much on the
# favorable side — depth-aware, so thin books show a worse (truer) price than top-of-book.
TARGET_POSITION_USD=50

# Adversarial refutation: when "true", the skeptic uses the provider OPPOSITE the
# analysis (Claude refutes OpenAI edges and vice-versa). Requires BOTH provider keys;
# if the opposite key is missing it falls back to same-model (logged). Blank = same-model.
CROSS_MODEL_ADVERSARIAL=

# Background auto-scan: hours between scan + resolution-sweep runs (blank/0 = off).
# Each run spends LLM budget (bounded by MAX_SCAN_MARKETS); set >= 24 so analyses are
# fresh (within max_age_hours they'd be reused and markets_scanned would read ~0).
# Logs one JSON line per run to data/scan_log.jsonl.
SCAN_INTERVAL_HOURS=

# Resolution-only sweep cadence (hours; blank/0 = off). Independent of SCAN_INTERVAL_HOURS.
# Sweeps are cheap (Gamma only, no LLM spend), so run them more often than full scans to
# capture resolutions before markets drop out of the active set. App-log only (not scan_log).
AUTO_RESOLUTION_INTERVAL_HOURS=

# Forward signal log: per-share EV floor an executable edge must clear to be logged as a
# forward signal (blank = 0.0). Auto-scans log automatically; manual scans only with
# {"log_signals": true}. Positions are sized at TARGET_POSITION_USD (above) and scored for
# realized P&L when the market resolves.
SIGNAL_MIN_EV=

# High-divergence alerts: an actionable edge (executable, ev>0) whose calibrated estimate
# diverges from the market mid by at least ALERT_MIN_DIVERGENCE is written to
# data/alerts.jsonl + the app log. ALERT_COOLDOWN_HOURS suppresses repeat alerts for the
# same market. If ALERT_WEBHOOK_URL is set, each alert is also POSTed (best-effort, stdlib).
ALERT_MIN_DIVERGENCE=0.15
ALERT_COOLDOWN_HOURS=24
ALERT_WEBHOOK_URL=
